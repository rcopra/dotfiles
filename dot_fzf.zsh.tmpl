# Setup fzf
# ---------
{{- if eq .chezmoi.os "darwin" }}
if [[ ! "$PATH" == */opt/homebrew/opt/fzf/bin* ]]; then
  PATH="${PATH:+${PATH}:}/opt/homebrew/opt/fzf/bin"
fi
{{- else if eq .chezmoi.os "linux" }}
# Linux - fzf typically installed via package manager or ~/.fzf
if [[ ! "$PATH" == */.fzf/bin* ]] && [[ -d "$HOME/.fzf/bin" ]]; then
  PATH="${PATH:+${PATH}:}$HOME/.fzf/bin"
fi
{{- end }}

# Theme colors
export FZF_DEFAULT_OPTS="
  --color=fg:{{ index .themes .theme "fg" }},bg:-1,hl:{{ index .themes .theme "accent" }}
  --color=fg+:{{ index .themes .theme "fg" }},bg+:{{ index .themes .theme "bg" }},hl+:{{ index .themes .theme "accent" }}
  --color=info:{{ index .themes .theme "green" }},prompt:{{ index .themes .theme "purple" }},pointer:{{ index .themes .theme "red" }}
  --color=marker:{{ index .themes .theme "yellow" }},spinner:{{ index .themes .theme "purple" }},header:{{ index .themes .theme "muted" }}
"

# Use fzf shell integration
command -v fzf > /dev/null && source <(fzf --zsh)
