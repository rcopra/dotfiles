# ============================================================================== 
# VS Code settings (managed via symlinks, not direct copies)
# ============================================================================== 
# These source files live under home/vscode/ and are symlinked to Library/
# Ignore the whole directory so chezmoi doesn't manage ~/vscode in targets
vscode
vscode/**

# ==============================================================================
# Neovim configuration (managed separately, not via chezmoi)
# ==============================================================================
.config/nvim
.config/nvim/**

# ==============================================================================
# macOS-only files - exclude on Linux
# ==============================================================================
{{ if ne .chezmoi.os "darwin" }}
# AeroSpace window manager (macOS only)
.aerospace.toml

# zsh config (use bash on Linux)
.zshrc
.zprofile
.fzf.zsh

# Karabiner keyboard remapper (macOS only)
.config/karabiner
.config/karabiner/**

# Tmux terminal multiplexer (not managed on Linux)
.tmux
.tmux/**
.tmux.conf

# Tmux sessionizer script (not managed on Linux)
bin/tmux-sessionizer

# WezTerm terminal emulator (macOS only)
.wezterm.lua

# Opencode (not managed on Linux)
.config/opencode
.config/opencode/**

# Claude Code (not managed on Linux)
.claude
.claude/**

# VS Code settings (macOS Library path)
Library
Library/**
{{ end }}

# ==============================================================================
# Server/headless machines - exclude GUI apps
# ==============================================================================
{{ if eq (index . "machineType" | default "personal") "server" }}
# Window managers
.aerospace.toml
.config/karabiner
.config/karabiner/**

# Terminal emulator config (use default terminal on servers)
.wezterm.lua

# VS Code (not installed on servers)
Library
Library/**
{{ end }}

# ============================================================================== 
# Work-only configuration
# ============================================================================== 
{{ if ne (index . "machineType" | default "personal") "work" }}
.config/gh-dash
.config/gh-dash/**
{{ end }}

# ==============================================================================
# SSH config (managed locally, not tracked in git)
# ==============================================================================
.ssh
.ssh/**

# ==============================================================================
# Claude Code (keep local except skills)
# ==============================================================================
.claude/*
!.claude/skills
!.claude/skills/**

# ==============================================================================
# Opencode (keep skills local, only manage config)
# ==============================================================================
.config/opencode/skills
.config/opencode/skills/**
