export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export EDITOR=nvim
export BUNDLER_EDITOR=nvim
export HOMEBREW_NO_ANALYTICS=1

export DISABLE_SPRING=true
export OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES
export PYENV_VIRTUALENV_DISABLE_PROMPT=1
export PYTHONBREAKPOINT=ipdb.set_trace

export PATH="/opt/homebrew/bin:${PATH}"
export PATH="/opt/homebrew/opt/postgresql@16/bin:$PATH"

export PATH="$HOME/bin:$HOME/.local/bin:$PATH"
export PATH="${HOME}/.rbenv/bin:${PATH}"
export PATH="./bin:./node_modules/.bin:${PATH}:/usr/local/sbin"

if type -a rbenv > /dev/null 2>&1; then
    eval "$(rbenv init - bash)"
fi

if type -a pyenv > /dev/null 2>&1; then
    eval "$(pyenv init - bash)"
fi

if type -a pyenv-virtualenv-init > /dev/null 2>&1; then
    eval "$(pyenv virtualenv-init -)"
fi

if command -v fnm > /dev/null 2>&1; then
    eval "$(fnm env --use-on-cd --log-level=quiet)"
fi

if command -v eza > /dev/null 2>&1; then
    export EZA_COLORS=".*=38;5;242"
    alias ls="eza --icons=always --group-directories-first"
    alias la="eza --icons=always --group-directories-first -a"
    alias ll="eza --icons=always --group-directories-first -l --header --git -h --time-style=long-iso"
    alias lla="eza --icons=always --group-directories-first -la --header --git -h --time-style=long-iso --follow-symlinks"
    alias lt="eza --icons=always --tree --level=2 --group-directories-first"
fi

if command -v direnv > /dev/null 2>&1; then
    eval "$(direnv hook bash)"
fi

if command -v starship > /dev/null 2>&1; then
    eval "$(starship init bash)"
fi

if command -v fzf > /dev/null 2>&1; then
    eval "$(fzf --bash)"
fi

if [ -f "$HOME/.aliases" ]; then
    . "$HOME/.aliases"
fi

if [ -f "$HOME/.bashrc.local" ]; then
    . "$HOME/.bashrc.local"
fi

# nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# zoxide must be initialized last
if command -v zoxide > /dev/null 2>&1; then
    eval "$(zoxide init bash --cmd cd)"
fi
