{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": [
      "/Users/rick/.config/opencode/skills",
      "/Users/rick/.claude/skills"
    ]
  },
  "permission": {
    "websearch": "allow"
  },
  "provider": {
    "byteplus": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "byteplus",
      "options": {
        "baseURL": "https://ark.ap-southeast.bytepluses.com/api/coding/v3",
        "apiKey": "{env:BYTEPLUS_API_KEY}"
      },
      "models": {
        "ark-code-latest": {
          "name": "ark-code-latest"
        },
        "bytedance-seed-code": {
          "name": "bytedance-seed-code"
        },
        "glm-4.7": {
          "name": "glm-4.7"
        },
        "gpt-oss-120b": {
          "name": "gpt-oss-120b"
        },
        "kimi-k2.5": {
          "name": "kimi-k2.5"
        }
      }
    }
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "prompt": "{file:./prompts/plan.md}",
      "model": "openrouter/openai/gpt-5.3-codex",
      "description": "Architectural planner using GPT-5.3 Codex. Returns reasoning_content automatically. Delegates to @explore for research.",
      "tools": {
        "write": false,
        "edit": false
      },
      "permission": {
        "bash": "ask"
      }
    },
    "build": {
      "mode": "primary",
      "model": "byteplus/glm-4.7",
      "description": "Primary agent for implementation. Delegates research to @explore."
    },
    "explore": {
      "mode": "subagent",
      "model": "openrouter/google/gemini-2.5-flash-lite",
      "description": "Fast, free read-only agent for codebase exploration. Use for finding files, searching code, and understanding project structure.",
      "tools": {
        "write": false,
        "edit": false
      },
      "permission": {
        "bash": "ask"
      }
    }
  }
}
