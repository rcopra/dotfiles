# ============================================================================== 
# Linux Installation
# ============================================================================== 

if command -v apt &> /dev/null; then
    echo "==> Detected apt (Debian-based)"

    sudo apt update
    sudo apt install -y \
        git \
        fzf \
        ripgrep \
        fd-find \
        bat \
        jq \
        bash \
        curl \
        wget \
        build-essential \
        direnv

    if ! command -v eza &> /dev/null; then
        echo "==> Installing eza..."
        sudo mkdir -p /etc/apt/keyrings
        wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc | sudo gpg --dearmor -o /etc/apt/keyrings/gierens.gpg
        echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" | sudo tee /etc/apt/sources.list.d/gierens.list
        sudo apt update
        sudo apt install -y eza
    fi

    if ! command -v zoxide &> /dev/null; then
        echo "==> Installing zoxide..."
        curl -sS https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | bash
    fi

    if ! command -v starship &> /dev/null; then
        echo "==> Installing starship..."
        curl -sS https://starship.rs/install.sh | sh -s -- -y
    fi

    if ! fc-list | grep -qi "{{ .nerdFont }}.*Nerd"; then
        echo "==> Installing {{ .nerdFont }} Nerd Font..."
        FONT_DIR="$HOME/.local/share/fonts"
        mkdir -p "$FONT_DIR"
        NERD_FONT_VERSION="v3.3.0"
        curl -fsSL "https://github.com/ryanoasis/nerd-fonts/releases/download/${NERD_FONT_VERSION}/{{ .nerdFont }}.zip" -o /tmp/NerdFont.zip
        unzip -o /tmp/NerdFont.zip -d "$FONT_DIR"
        rm /tmp/NerdFont.zip
        fc-cache -fv
    fi
elif command -v pacman &> /dev/null; then
    echo "==> Detected pacman (Arch-based)"

    sudo pacman -Syu --noconfirm \
        git \
        fzf \
        eza \
        zoxide \
        ripgrep \
        fd \
        bat \
        jq \
        bash \
        base-devel \
        direnv

    if ! command -v starship &> /dev/null; then
        sudo pacman -S --noconfirm starship
    fi

    {{- $pacmanFontMap := dict "Hack" "ttf-hack-nerd" "JetBrainsMono" "ttf-jetbrains-mono-nerd" "FiraCode" "ttf-firacode-nerd" "CascadiaCode" "ttf-cascadia-code-nerd" "Iosevka" "ttf-iosevka-nerd" "VictorMono" "ttf-victor-mono-nerd" "SourceCodePro" "ttf-sourcecodepro-nerd" "UbuntuMono" "ttf-ubuntu-mono-nerd" "Meslo" "ttf-meslo-nerd" }}
    if ! pacman -Q {{ get $pacmanFontMap .nerdFont }} &> /dev/null; then
        echo "==> Installing {{ .nerdFont }} Nerd Font..."
        sudo pacman -S --noconfirm {{ get $pacmanFontMap .nerdFont }}
    fi
fi

# ============================================================================== 
# Set bash as default shell
# ============================================================================== 

if command -v bash &> /dev/null && [ "$SHELL" != "$(command -v bash)" ]; then
    echo "==> Setting bash as default shell..."
    chsh -s "$(command -v bash)"
fi

# ============================================================================== 
# Universal Linux: Version Managers
# ============================================================================== 

if [ ! -d "$HOME/.rbenv" ]; then
    echo "==> Installing rbenv..."
    git clone https://github.com/rbenv/rbenv.git ~/.rbenv
    git clone https://github.com/rbenv/ruby-build.git ~/.rbenv/plugins/ruby-build
fi

if [ ! -d "$HOME/.pyenv" ]; then
    echo "==> Installing pyenv..."
    curl https://pyenv.run | bash
fi

if [ ! -d "$HOME/.nvm" ]; then
    echo "==> Installing nvm..."
    curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.0/install.sh | bash
fi
