# chezmoi:template:left-delimiter=(( right-delimiter=))
version = 4
final_space = true
console_title_template = '{{ .Folder }}'

[palette]
  fg     = '(( index .themes .theme "fg" ))'
  muted  = '(( index .themes .theme "muted" ))'
  accent = '(( index .themes .theme "accent" ))'
  green  = '(( index .themes .theme "green" ))'
  red    = '(( index .themes .theme "red" ))'
  yellow = '(( index .themes .theme "yellow" ))'
  orange = '(( index .themes .theme "orange" ))'
  purple = '(( index .themes .theme "purple" ))'
  teal   = '(( index .themes .theme "teal" ))'

# First line - path, git, fill, hostname, time
[[blocks]]
  type = 'prompt'
  alignment = 'left'

  [[blocks.segments]]
    type = 'os'
    style = 'plain'
    foreground = 'p:fg'
    template = '{{ .Icon }}'

  [[blocks.segments]]
    type = 'text'
    style = 'plain'
    foreground = 'p:muted'
    template = '─'

  [[blocks.segments]]
    type = 'path'
    style = 'plain'
    foreground = 'p:accent'
    template = ' {{ .Path }}'
    [blocks.segments.properties]
      style = 'full'

  [[blocks.segments]]
    type = 'git'
    style = 'plain'
    foreground = 'p:orange'
    template = ' {{ .HEAD }}{{ if or .Working.Changed .Staging.Changed .Working.Untracked }} {{ end }}{{ if .Working.Changed }}<p:red>!{{ .Working.Changed }}</>{{ end }}{{ if .Working.Untracked }}<p:red>?{{ .Working.Untracked }}</>{{ end }}{{ if .Staging.Changed }}<p:green>+{{ .Staging.Changed }}</>{{ end }}{{ if gt .StashCount 0 }}<p:purple>*{{ .StashCount }}</>{{ end }}'
    [blocks.segments.properties]
      fetch_status = true
      branch_icon = ''

[[blocks]]
  type = 'prompt'
  alignment = 'right'

  [[blocks.segments]]
    type = 'executiontime'
    style = 'plain'
    foreground = 'p:muted'
    template = ' {{ .FormattedMs }}'
    [blocks.segments.properties]
      threshold = 500
      style = 'roundrock'

  [[blocks.segments]]
    type = 'time'
    style = 'plain'
    foreground = 'p:purple'
    template = ' {{ .CurrentDate | date "15:04:05" }}'

# Second line - prompt character
[[blocks]]
  type = 'prompt'
  alignment = 'left'
  newline = true

  [[blocks.segments]]
    type = 'text'
    style = 'plain'
    foreground = 'p:muted'
    template = '╰─'

  [[blocks.segments]]
    type = 'status'
    style = 'plain'
    foreground = 'p:accent'
    foreground_templates = ['{{ if gt .Code 0 }}p:red{{ end }}']
    template = '❯ '

# Transient prompt for cleaner history
[transient_prompt]
  foreground = 'p:accent'
  foreground_templates = ['{{ if gt .Code 0 }}p:red{{ end }}']
  template = '❯ '
