{{- /* chezmoi:template:left-delimiter=(( right-delimiter=)) */ -}}
{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "final_space": true,
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "palette": {
    "fg":     "(( index .themes .theme "fg" ))",
    "muted":  "(( index .themes .theme "muted" ))",
    "accent": "(( index .themes .theme "accent" ))",
    "green":  "(( index .themes .theme "green" ))",
    "red":    "(( index .themes .theme "red" ))",
    "yellow": "(( index .themes .theme "yellow" ))",
    "orange": "(( index .themes .theme "orange" ))",
    "purple": "(( index .themes .theme "purple" ))",
    "teal":   "(( index .themes .theme "teal" ))"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:muted",
          "template": "─"
        },
        {
          "type": "os",
          "style": "plain",
          "foreground": "p:fg",
          "template": " {{ .Icon }} "
        },
        {
          "type": "session",
          "style": "plain",
          "foreground": "p:muted",
          "template": "{{ (split \".\" .HostName)._0 }} ",
          "properties": {
            "display_host": true,
            "display_user": false
          }
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "p:accent",
          "template": "\uf07c {{ .Path }}",
          "properties": {
            "style": "full",
            "folder_icon": "\uf07c",
            "home_icon": "~"
          }
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "p:orange",
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{ if .Working.Changed }} <p:red>{{ .Working.String }}</>{{ end }}{{ if .Staging.Changed }}<p:green> {{ .Staging.String }}</>{{ end }}{{ if gt .StashCount 0 }}<p:purple> {{ .StashCount }}</>{{ end }}",
          "properties": {
            "branch_icon": "\uf126 ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "filler": "<p:muted>·</>",
      "segments": [
        {
          "type": "node",
          "style": "plain",
          "foreground": "p:teal",
          "template": " \ue718 {{ .Full }}",
          "properties": {
            "display_mode": "files",
            "fetch_version": true
          }
        },
        {
          "type": "python",
          "style": "plain",
          "foreground": "p:yellow",
          "template": " \ue235 {{ .Full }}",
          "properties": {
            "display_mode": "files",
            "fetch_version": true
          }
        },
        {
          "type": "ruby",
          "style": "plain",
          "foreground": "p:red",
          "template": " \ue791 {{ .Full }}",
          "properties": {
            "display_mode": "files",
            "fetch_version": true
          }
        },
        {
          "type": "go",
          "style": "plain",
          "foreground": "p:teal",
          "template": " \ue627 {{ .Full }}",
          "properties": {
            "display_mode": "files",
            "fetch_version": true
          }
        },
        {
          "type": "php",
          "style": "plain",
          "foreground": "p:purple",
          "template": " \ue73d {{ .Full }}",
          "properties": {
            "display_mode": "files",
            "fetch_version": true
          }
        },
        {
          "type": "julia",
          "style": "plain",
          "foreground": "p:purple",
          "template": " \ue624 {{ .Full }}",
          "properties": {
            "display_mode": "files",
            "fetch_version": true
          }
        },
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "p:muted",
          "template": " {{ .FormattedMs }}",
          "properties": {
            "threshold": 0,
            "style": "austin",
            "always_enabled": true
          }
        },
        {
          "type": "time",
          "style": "plain",
          "foreground": "p:purple",
          "template": " \uf017 {{ .CurrentDate | date \"03:04:05 PM\" }}"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:muted",
          "template": "╰─"
        },
        {
          "type": "status",
          "style": "plain",
          "foreground": "p:green",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:red{{ end }}"
          ],
          "template": "❯ ",
          "properties": {
            "always_enabled": true
          }
        }
      ]
    }
  ]
}
